# ---------- App ----------
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-frontend.vercel.app

# ---------- Supabase ----------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------- JWT Auth ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---------- AI Provider ----------
# "groq" (recommended, free & fast) or "gemini"
AI_PROVIDER=groq

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ---------- Admin ----------
# Comma-separated emails that are auto-treated as admins
ADMIN_EMAILS=you@example.com
